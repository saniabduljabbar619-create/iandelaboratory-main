# ========================================
# Solunex Bundle .gitignore
# ========================================

# --- Virtual Environments ---
.venv/
venv/
env/

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# --- Environment Variables & Secrets ---
.env
.env.local
.env.*.local

# --- PyInstaller & Inno Setup Build Artifacts ---
